DIM valorreais AS SINGLE
DIM valordolares AS SINGLE
DIM valoreuro AS SINGLE

PRINT "Valor em reais:"
INPUT valorreais

valordolares = valorreais * 5
valoreuro = valorreais * 5.4

PRINT
PRINT "Valor em reais: "; valorreais
PRINT "Valor em dolares: "; valordolares
PRINT "Valor em euro: "; valoreuro

END